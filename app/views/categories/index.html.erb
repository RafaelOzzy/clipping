<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Categorias</h1>
    <%= link_to "Nova Categoria", new_category_path, class: "btn btn-primary" %>
  </div>

  <table class="table table-striped">
    <thead>
      <tr>
        <th>Nome</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @categories.each do |category| %>
        <tr>
          <td><%= category.name %></td>
          <td>
            <%= link_to "Ver", category_path(category), class: "btn btn-sm btn-info" %>
            <%= link_to "Editar", edit_category_path(category), class: "btn btn-sm btn-warning" %>
            <%= link_to "Deletar", category_path(category), data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" }, class: "btn btn-sm btn-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

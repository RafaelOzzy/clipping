<div class="container mt-4">
  <div class="card">
    <div class="card-header">
      <h1><%= @article.title %></h1>
    </div>
    <div class="card-body">
      <p><strong>Fonte:</strong> <%= @article.source.name %></p>
      <p><strong>Data de Publicação:</strong> <%= @article.published_at&.strftime("%d/%m/%Y") %></p>
      <p><strong>URL:</strong> <%= link_to @article.url, @article.url, target: "_blank" %></p>
      <p><strong>Categorias:</strong> <%= @article.categories.map(&:name).join(", ") %></p>
      <hr>
      <div><%= @article.content %></div>
    </div>
  </div>

  <div class="mt-3">
    <%= link_to "Editar", edit_article_path(@article), class: "btn btn-warning" %>
    <%= link_to "Voltar", articles_path, class: "btn btn-secondary" %>
  </div>
</div>

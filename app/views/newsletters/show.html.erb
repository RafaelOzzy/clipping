<div class="container mt-4">
  <div class="card">
    <div class="card-header">
      <h1><%= @newsletter.title %></h1>
    </div>
    <div class="card-body">
      <p><strong>Data de Envio:</strong> <%= @newsletter.sent_at&.strftime("%d/%m/%Y") %></p>
      <p><strong>Enviado:</strong> <%= @newsletter.sent ? "Sim" : "Não" %></p>
      <hr>
      <h4>Artigos</h4>
      <% @newsletter.articles.each do |article| %>
        <div class="card mb-2">
          <div class="card-body">
            <h5><%= article.title %></h5>
            <p><strong>Fonte:</strong> <%= article.source.name %></p>
            <%= link_to "Ver artigo", article_path(article), class: "btn btn-sm btn-info" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-3">
    <%= link_to "Editar", edit_newsletter_path(@newsletter), class: "btn btn-warning" %>
    <%= link_to "Voltar", newsletters_path, class: "btn btn-secondary" %>
  </div>
</div>

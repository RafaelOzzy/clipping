<div class="container mt-4">
  <div class="card">
    <div class="card-header">
      <h1>Categoria</h1>
    </div>
    <div class="card-body">
      <p><strong>Nome:</strong> <%= @category.name %></p>
    </div>
  </div>

  <div class="mt-3">
    <%= link_to "Editar", edit_category_path(@category), class: "btn btn-warning" %>
    <%= link_to "Voltar", categories_path, class: "btn btn-secondary" %>
  </div>
</div>

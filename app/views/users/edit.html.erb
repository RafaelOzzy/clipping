<div class="container mt-4">
  <h1>Editar Usuário</h1>

  <%= form_with model: @user do |form| %>
    <div class="mb-3">
      <%= form.label :name, "Nome", class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= form.label :company, "Empresa", class: "form-label" %>
      <%= form.text_field :company, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= form.label :cnpj, "CNPJ", class: "form-label" %>
      <%= form.text_field :cnpj, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= form.label :role, "Role", class: "form-label" %>
      <%= form.select :role, [["Usuário", "user"], ["Admin", "admin"]], {}, { class: "form-select" } %>
    </div>

    <div class="mb-3 form-check">
      <%= form.check_box :active, class: "form-check-input" %>
      <%= form.label :active, "Ativo", class: "form-check-label" %>
    </div>

    <%= form.submit "Salvar", class: "btn btn-primary" %>
  <% end %>

  <%= link_to "Voltar", users_path, class: "btn btn-secondary mt-2" %>
</div>

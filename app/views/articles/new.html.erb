<div class="container mt-4">
  <h1>Novo Artigo</h1>

  <%= form_with model: @article do |form| %>
    <div class="mb-3">
      <%= form.label :title, "Título", class: "form-label" %>
      <%= form.text_field :title, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= form.label :source_id, "Fonte", class: "form-label" %>
      <%= form.collection_select :source_id, Source.all, :id, :name, { prompt: "Selecione uma fonte" }, { class: "form-select" } %>
    </div>

    <div class="mb-3">
      <%= form.label :published_at, "Data de Publicação", class: "form-label" %>
      <%= form.datetime_local_field :published_at, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= form.label :url, "URL", class: "form-label" %>
      <%= form.text_field :url, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= form.label :category_ids, "Categorias", class: "form-label" %>
      <%= form.collection_check_boxes :category_ids, Category.all, :id, :name do |cb| %>
        <div class="form-check">
          <%= cb.check_box class: "form-check-input" %>
          <%= cb.label class: "form-check-label" %>
        </div>
      <% end %>
    </div>

    <div class="mb-3">
      <%= form.label :content, "Conteúdo", class: "form-label" %>
      <%= form.rich_text_area :content %>
    </div>

    <%= form.submit "Salvar", class: "btn btn-primary" %>
  <% end %>

  <%= link_to "Voltar", articles_path, class: "btn btn-secondary mt-2" %>
</div>

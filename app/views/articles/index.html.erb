<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Artigos</h1>
    <% if current_user.admin? %>
    <%= link_to "Novo Artigo", new_article_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <table class="table table-striped">
    <thead>
      <tr>
        <th>Título</th>
        <th>Fonte</th>
        <th>Data de Publicação</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @articles.each do |article| %>
        <tr>
          <td><%= article.title %></td>
          <td><%= article.source.name %></td>
          <td><%= article.published_at&.strftime("%d/%m/%Y") %></td>
          <td>
            <%= link_to "Ver", article_path(article), class: "btn btn-sm btn-info" %>
            <% if current_user.admin? %>
            <%= link_to "Editar", edit_article_path(article), class: "btn btn-sm btn-warning" %>
            <%= link_to "Deletar", article_path(article), data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" }, class: "btn btn-sm btn-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

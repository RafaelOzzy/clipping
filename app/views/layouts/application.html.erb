<!DOCTYPE html>
<html>
  <head>
    <title>Clipping</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
  <% if user_signed_in? %>
  <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #1a2b4a;">
    <div class="container">
      <a class="navbar-brand fw-bold" href="#">Clippings</a>
      <div class="navbar-nav ms-auto">
        <%= link_to "Clippings", newsletters_path, class: "nav-link text-white" %>
        <%= link_to "Artigos", articles_path, class: "nav-link text-white" %>
        <% if current_user.admin? %>
          <%= link_to "Fontes", sources_path, class: "nav-link text-white" %>
          <%= link_to "Categorias", categories_path, class: "nav-link text-white" %>
        <% end %>
        <%= link_to "Sair", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link text-white" %>
      </div>
    </div>
  </nav>
  <% end %>
    <% if notice %>
      <div class="alert alert-success alert-dismissible fade show m-0" role="alert">
        <%= notice %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <% if alert %>
      <div class="alert alert-danger alert-dismissible fade show m-0" role="alert">
        <%= alert %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>
    <%= yield %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
